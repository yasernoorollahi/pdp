<!--    </logger>-->


    <!-- ================= CONSOLE ================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{HH:mm:ss.SSS}){faint} [%X{traceId}] %clr(%-5level) %clr(%logger{36}){cyan} - %msg%n
            </pattern>
        </encoder>
    </appender>


    <!-- ================= LOGGERS ================= -->

    <!-- Hibernate SQL -->
    <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
        <appender-ref ref="SQL_FILE"/>
    </logger>

    <!-- Transaction logs -->
    <logger name="org.springframework.transaction" level="TRACE" additivity="false">
        <appender-ref ref="TX_FILE"/>
    </logger>


    <logger name="com.datarain.pdp.job" level="INFO" additivity="false">
        <appender-ref ref="JOB_FILE"/>
    </logger>


    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>
